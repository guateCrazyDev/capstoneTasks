<configuration>

    <!-- ========================= -->
    <!-- PROPERTIES -->
    <!-- ========================= -->
    <property name="APP_NAME" value="support-ticket"/>
    <property name="LOG_PATH" value="${user.dir}/supportTicket/logs"/>
    <property name="LOG_LEVEL" value="INFO"/>

    <!-- ========================= -->
    <!-- JSON FILE APPENDER -->
    <!-- ========================= -->
    <appender name="JSON_FILE"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_PATH}/${APP_NAME}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>
                {
                  "app":"${APP_NAME}",
                  "environment":"dev"
                }
            </customFields>
            <excludeFieldNames>
                version,level_value
            </excludeFieldNames>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- HTTP LOG APPENDER -->
    <!-- ========================= -->
    <appender name="HTTP_JSON"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>${LOG_PATH}/${APP_NAME}-http.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_PATH}/${APP_NAME}-http.%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>15</maxHistory>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>

    <!-- ========================= -->
    <!-- LOGGER HTTP -->
    <!-- ========================= -->
    <logger name="com.supportTicket.supportTicket.loggingConfig.HttpLoggingFilter"
            level="INFO"
            additivity="false">
        <appender-ref ref="HTTP_JSON"/>
    </logger>

    <!-- ========================= -->
    <!-- CONSOLE -->
    <!-- ========================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%level] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ========================= -->
    <!-- ROOT -->
    <!-- ========================= -->
    <root level="${LOG_LEVEL}">
        <appender-ref ref="JSON_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>